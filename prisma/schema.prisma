generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String?
  role      UserRole
  status    UserStatus @default(ACTIVE)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  candidateProfile CandidateProfile?
  employerProfile  EmployerProfile?
}

model CandidateProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique

  fullName           String
  phone              String?
  district           String?
  currentRole        String?
  preferredLocations Json?
  expectedSalary     Int?
  experienceYears    Float    @default(0)

  skills             Json?
  languages          Json?
  education          String?
  linkedinUrl        String?
  githubUrl          String?
  portfolioUrl       String?
  profileImageUrl    String?

  profileCompletion  Int      @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id])
  applications       Application[]
  savedJobs          SavedJob[]
  cvAnalyses         CvAnalysis[]
}

model EmployerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  companyId String?

  fullName  String
  position  String?
  phone     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  company   Company? @relation(fields: [companyId], references: [id])
}

model Company {
  id           String        @id @default(cuid())

  name         String
  logoText     String
  logoType     String
  logoColor    String

  industry     String
  location     String
  openJobs     Int           @default(0)
  size         String?
  website      String?
  description  String?
  contactEmail String?
  phone        String?

  status       CompanyStatus @default(PENDING)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  jobs         Job[]
  employers    EmployerProfile[]
  adminActions AdminAction[]
}

model Category {
  id          String   @id @default(cuid())

  name        String   @unique
  jobCount    Int      @default(0)
  iconName    String
  description String?
  topSkills   Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs        Job[]
}

model Job {
  id               String          @id @default(cuid())

  companyId        String
  categoryId       String

  title            String
  location         String
  workMode         WorkMode
  jobType          JobType
  salaryMin        Int
  salaryMax        Int
  experienceLevel  ExperienceLevel

  skills           Json
  preferredSkills  Json?
  description      String?
  responsibilities Json?
  benefits         Json?

  status           JobStatus       @default(PENDING_APPROVAL)
  isFeatured       Boolean         @default(false)
  applicantCount   Int             @default(0)
  postedDate       String?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  company          Company         @relation(fields: [companyId], references: [id])
  category         Category        @relation(fields: [categoryId], references: [id])

  applications     Application[]
  savedJobs        SavedJob[]
  adminActions     AdminAction[]
}

model Application {
  id            String            @id @default(cuid())

  candidateId   String
  jobId         String

  coverLetter   String
  status        ApplicationStatus @default(APPLIED)
  matchScore    Int?

  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  withdrawnAt   DateTime?

  candidate     CandidateProfile  @relation(fields: [candidateId], references: [id])
  job           Job               @relation(fields: [jobId], references: [id])

  interview     Interview?
}

model SavedJob {
  id          String   @id @default(cuid())

  candidateId String
  jobId       String

  createdAt   DateTime @default(now())

  candidate   CandidateProfile @relation(fields: [candidateId], references: [id])
  job         Job              @relation(fields: [jobId], references: [id])

  @@unique([candidateId, jobId])
}

model CvAnalysis {
  id              String   @id @default(cuid())

  candidateId     String

  fileName        String
  fileUrl         String?
  strengthScore   Int

  extractedSkills Json?
  missingSkills   Json?
  experienceYears Float    @default(0)
  education       Json?
  languages       Json?
  suggestions     Json?

  createdAt       DateTime @default(now())

  candidate       CandidateProfile @relation(fields: [candidateId], references: [id])
}

model Interview {
  id             String          @id @default(cuid())

  applicationId  String          @unique

  interviewDate  String
  interviewTime  String
  interviewType  InterviewType
  locationOrLink String?
  notes          String?
  status         InterviewStatus @default(SCHEDULED)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  application    Application     @relation(fields: [applicationId], references: [id])
}

model AdminAction {
  id          String          @id @default(cuid())

  adminUserId String?
  entityType  AdminEntityType
  entityId    String
  action      AdminActionType
  reason      String?

  companyId   String?
  jobId       String?

  createdAt   DateTime        @default(now())

  company     Company?        @relation(fields: [companyId], references: [id])
  job         Job?            @relation(fields: [jobId], references: [id])
}

enum UserRole {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum ExperienceLevel {
  ENTRY_LEVEL
  ONE_TO_TWO_YEARS
  THREE_TO_FIVE_YEARS
  FIVE_PLUS_YEARS
}

enum JobStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  CLOSED
  REJECTED
}

enum ApplicationStatus {
  APPLIED
  VIEWED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  REJECTED
  HIRED
  WITHDRAWN
}

enum InterviewType {
  ONLINE
  ONSITE
  PHONE
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AdminEntityType {
  COMPANY
  JOB
}

enum AdminActionType {
  APPROVED
  REJECTED
  SUSPENDED
  CLOSED
  FEATURED
}